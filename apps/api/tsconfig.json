{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./dist",
    "noEmit": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "ES2022",
    "paths": {
      "@crypto-screener/shared": ["../../packages/shared/src"],
      "@crypto-screener/exchange-connectors": ["../../packages/exchange-connectors/src"]
    },
    "baseUrl": "."
  },
  "include": ["src/**/*", "../../packages/shared/src/**/*", "../../packages/exchange-connectors/src/**/*"]
}
