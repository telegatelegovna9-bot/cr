# Environment Variables

# Database (Railway PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/crypto_screener

# Redis (Railway Redis)
REDIS_URL=redis://localhost:6379

# Server
PORT=3001
NODE_ENV=development

# CORS
CORS_ORIGINS=http://localhost:3000

# Rate Limiting
RATE_LIMIT_MAX=100

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=http://localhost:3001

# Telegram (optional)
TELEGRAM_BOT_TOKEN=

# Monitoring (optional)
SENTRY_DSN=
